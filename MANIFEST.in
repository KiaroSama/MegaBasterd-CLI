include README.md
include LICENSE
include ATTRIBUTION.md
include CHANGELOG.md
include CONTRIBUTING.md
include SECURITY.md
include pyproject.toml
include requirements.txt
include Run.ps1
# Run.ps1 loads this at runtime; an sdist without it has a launcher that
# cannot log.
recursive-include launcher *.cs
recursive-include docs *.md
recursive-include src *.py
recursive-include src *.typed
recursive-include src/megabasterd_cli/native *.c
recursive-include tests *.py
recursive-include tools *.ps1
global-exclude __pycache__
global-exclude *.pyc
global-exclude *.pyo
